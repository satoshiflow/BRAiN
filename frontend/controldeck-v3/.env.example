# ControlDeck v3 Environment Configuration
# Copy this file to .env.local and adjust values as needed

# API Configuration
NEXT_PUBLIC_BRAIN_API_BASE=http://localhost:8000
NEXT_PUBLIC_BRAIN_API_PATH=/api

# AXE UI URL (for link back to AXE UI)
NEXT_PUBLIC_AXE_UI_BASE=http://localhost:3002

# Runtime Mode
NEXT_PUBLIC_APP_ENV=local

# Auth Configuration
NEXT_PUBLIC_AUTH_SECRET=your-secret-key-here-min-32-chars
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRY_HOURS=2

# Feature Flags
NEXT_PUBLIC_ENABLE_HEALTH_STREAM=true
NEXT_PUBLIC_ENABLE_IMMUNE_STREAM=true
