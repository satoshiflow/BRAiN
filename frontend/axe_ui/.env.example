# AXE UI Environment Configuration Example
# Follows Runtime Deployment Contract (docs/specs/runtime_deployment_contract.md)
#
# COPY THIS FILE TO .env.local AND ADJUST VALUES

# ============================================
# RUNTIME MODE
# ============================================
# Options: auto | local | production
# Default: auto (hostname-based detection)
#
# Local Development:
NEXT_PUBLIC_APP_ENV=local

# Production/Remote:
# NEXT_PUBLIC_APP_ENV=production

# ============================================
# BACKEND API BASE URL
# ============================================
# Local Development (laptop):
NEXT_PUBLIC_BRAIN_API_BASE=http://127.0.0.1:8000

# Remote/Staging:
# NEXT_PUBLIC_BRAIN_API_BASE=https://staging-api.brain.falklabs.de

# Production:
# NEXT_PUBLIC_BRAIN_API_BASE=https://api.brain.falklabs.de

# ============================================
# LLM MODEL CONFIGURATION
# ============================================
# Default model for AXE chat
#
# Local (lightweight):
NEXT_PUBLIC_AXE_DEFAULT_MODEL=qwen2.5:0.5b

# Remote (more capable):
# NEXT_PUBLIC_AXE_DEFAULT_MODEL=qwen2.5:1.5b

# ============================================
# NOTES
# ============================================
# - Auto-detection: If NEXT_PUBLIC_APP_ENV=auto (or unset), AXE UI detects
#   runtime mode based on hostname (localhost/127.0.0.1 = local, else production)
#
# - Explicit override: Set NEXT_PUBLIC_BRAIN_API_BASE to override auto-detection
#
# - Production builds: Never point to localhost in production .env
#
# - For more details see: docs/specs/runtime_deployment_contract.md
