{
  "name": "axe-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "python3 scripts/run_dev.py",
    "dev:direct": "next dev -p 3002",
    "dev:e2e": "NEXT_DIST_DIR=.next-e2e next dev -p 3012 --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test e2e/smoke/auth.spec.ts e2e/smoke/chat-sessions.spec.ts e2e/smoke/upload-camera.spec.ts --project=chromium",
    "test:e2e:all": "playwright test",
    "verify:runtime": "python3 scripts/verify_runtime.py",
    "verify:frontend": "npm run typecheck && npm run lint && npm run build"
  },
  "dependencies": {
    "@monaco-editor/react": "4.6.0",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-label": "2.0.2",
    "@radix-ui/react-popover": "1.0.7",
    "@radix-ui/react-scroll-area": "1.0.5",
    "@radix-ui/react-select": "2.0.0",
    "@radix-ui/react-separator": "1.0.3",
    "@radix-ui/react-slot": "1.0.2",
    "@radix-ui/react-switch": "1.0.3",
    "@radix-ui/react-tabs": "1.0.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.378.0",
    "monaco-editor": "0.45.0",
    "next": "14.2.33",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-resizable-panels": "2.0.19",
    "tailwind-merge": "^2.3.0",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "20.12.7",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.33",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.3",
    "typescript": "5.4.5"
  }
}
