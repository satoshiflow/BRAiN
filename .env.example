# BRAiN Local Micro Environment (8 GB RAM profile)
# Copy this file to .env before starting the local stack.

# -----------------------------------------------------------------------------
# Runtime identity and mode
# -----------------------------------------------------------------------------
APP_ENV=development
BRAiN_MODE=development

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=brain_dev
POSTGRES_USER=brain
POSTGRES_PASSWORD=brain_dev_pass
POSTGRES_PORT_HOST=5432
DATABASE_URL=postgresql+asyncpg://brain:brain_dev_pass@postgres:5432/brain_dev

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT_HOST=6379
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_HTTP_PORT_HOST=6333
QDRANT_GRPC_PORT_HOST=6334
QDRANT_URL=http://qdrant:6333

# -----------------------------------------------------------------------------
# Mock LLM (optional local placeholder)
# Start with: docker compose --profile mock-llm -f docker-compose.dev.yml up -d
# -----------------------------------------------------------------------------
MOCK_LLM_PORT_HOST=8081
MOCK_LLM_URL=http://mock-llm:8080
MOCK_LLM_MODE=rules
MOCK_LLM_LATENCY_MIN_MS=40
MOCK_LLM_LATENCY_MAX_MS=140
MOCK_LLM_ERROR_RATE=0.0
MOCK_LLM_ERROR_STATUS=503
MOCK_LLM_ERROR_TRIGGER=trigger_error
MOCK_LLM_ALLOW_STREAM=false

# -----------------------------------------------------------------------------
# LLM abstraction (engine-agnostic)
# Keep this API-first so local profile can switch to external OpenAI-compatible
# servers later without architecture changes.
# -----------------------------------------------------------------------------
LLM_MODE=mock
LLM_API_BASE=http://mock-llm:8080/v1
LLM_API_KEY=dev-placeholder-key
LLM_DEFAULT_MODEL=mock-local

# Example external OpenAI-compatible endpoint for later migration:
# LLM_MODE=external
# LLM_API_BASE=https://your-llm-gateway.example.com/v1
# LLM_API_KEY=replace-me
# LLM_DEFAULT_MODEL=your-model-name

# -----------------------------------------------------------------------------
# BRAiN API / local dev defaults
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
